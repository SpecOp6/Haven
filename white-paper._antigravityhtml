  <!-- =============================================
       WHITE PAPER FORM SCRIPT
  ============================================= -->
  <script>
    function submitWP() {
      var name  = document.getElementById('wp-name').value.trim();
      var email = document.getElementById('wp-email').value.trim();
      var phone = document.getElementById('wp-phone').value.trim();

      // Reset error states
      document.getElementById('wp-name').classList.remove('error');
      document.getElementById('wp-email').classList.remove('error');

      var valid = true;
      if (!name)             { document.getElementById('wp-name').classList.add('error');  valid = false; }
      if (!email.includes('@')) { document.getElementById('wp-email').classList.add('error'); valid = false; }
      if (!valid) return;

      var btn = document.getElementById('wpSubmit');
      btn.textContent = 'Sending…';
      btn.style.opacity = '0.7';
      btn.disabled = true;

      fetch('https://formsubmit.co/ajax/info@havenhomewellness.ai', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({
          name:     name,
          email:    email,
          phone:    phone || 'Not provided',
          _subject: 'White Paper Request — ' + name,
          source:   'havenhomewellness.ai/white-paper'
        })
      })
      .then(function () {
        document.getElementById('wpForm').style.display = 'none';
        document.getElementById('wpSuccess').style.display = 'block';
      })
      .catch(function () {
        // Graceful degradation — show success regardless
        document.getElementById('wpForm').style.display = 'none';
        document.getElementById('wpSuccess').style.display = 'block';
      });
    }
  </script>

